{
  "name": "notepad-plus-plus",
  "productName": "Notepadd++",
  "version": "1.0.0",
  "description": "Notepadd++ desktop app built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-native": "node -e \"const v=require('electron/package.json').version; require('child_process').execSync('cd native && node-gyp rebuild --target='+v+' --arch=x64 --dist-url=https://electronjs.org/headers', {stdio:'inherit'})\"",
    "dist-packaged": "npm run build-native && electron-packager . \"Notepadd++\" --platform=win32 --arch=x64 --out=dist-packaged --overwrite --asar.unpackDir=native/build/Release"
  },
  "keywords": [
    "electron",
    "browser"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-packager": "^17.1.2",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.3.0"
  }
}
